# PostgreSQL local (configurado em compose.yaml)
DATABASE_URL="postgresql://controle:controle@localhost:5432/controle_financeiro?schema=public"

# Supabase Auth (chave publicável; nunca use service_role no navegador)
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# IDs dos únicos usuários autorizados no Supabase Auth, separados por vírgula
AUTHORIZED_USER_IDS="uuid-matheus,uuid-karina"
